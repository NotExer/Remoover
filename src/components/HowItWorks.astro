<section id="how-it-works" class="py-24 bg-white">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-semibold text-[#1d1d1f] tracking-tight">
        Como funciona
      </h2>
      <p class="mt-4 text-lg text-[#6e6e73]">
        Tres simples pasos para obtener tu imagen transparente.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-16">
      <div class="flex flex-col items-center text-center">
        <div
          class="w-14 h-14 rounded-full bg-[#f5f5f7] flex items-center justify-center text-xl font-semibold text-[#1d1d1f] mb-6"
        >
          1
        </div>
        <h3 class="text-lg font-semibold text-[#1d1d1f] mb-2">
          Sube tu imagen
        </h3>
        <p class="text-[#6e6e73] text-sm leading-relaxed">
          Arrastra y suelta tu archivo o haz clic para seleccionar una
          foto de tu galeria.
        </p>
      </div>

      <div class="flex flex-col items-center text-center">
        <div
          class="w-14 h-14 rounded-full bg-[#f5f5f7] flex items-center justify-center text-xl font-semibold text-[#1d1d1f] mb-6"
        >
          2
        </div>
        <h3 class="text-lg font-semibold text-[#1d1d1f] mb-2">
          Procesamiento automatico
        </h3>
        <p class="text-[#6e6e73] text-sm leading-relaxed">
          La IA analiza la imagen y elimina el fondo instantaneamente
          con alta precision.
        </p>
      </div>

      <div class="flex flex-col items-center text-center">
        <div
          class="w-14 h-14 rounded-full bg-[#f5f5f7] flex items-center justify-center text-xl font-semibold text-[#1d1d1f] mb-6"
        >
          3
        </div>
        <h3 class="text-lg font-semibold text-[#1d1d1f] mb-2">
          Descarga el resultado
        </h3>
        <p class="text-[#6e6e73] text-sm leading-relaxed">
          Obten tu imagen en formato PNG transparente lista para usar
          en tus disenos.
        </p>
      </div>
    </div>
  </div>
</section>
