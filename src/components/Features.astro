---

---

<section id="features" class="py-24 bg-[#f5f5f7]">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-semibold text-[#1d1d1f] tracking-tight">
        Por que elegir RemooVI
      </h2>
      <p class="mt-4 text-lg text-[#6e6e73]">
        Tecnologia avanzada para resultados perfectos.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div
        class="bg-white p-8 rounded-2xl transition-all duration-300 hover:-translate-y-1 hover:shadow-lg"
      >
        <div
          class="w-10 h-10 bg-[#f5f5f7] rounded-xl flex items-center justify-center mb-6"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5 text-[#1d1d1f]"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-[#1d1d1f] mb-2">
          Velocidad
        </h3>
        <p class="text-[#6e6e73] text-sm leading-relaxed">
          Procesa tus imagenes en segundos con infraestructura optimizada.
          Sin esperas innecesarias.
        </p>
      </div>

      <div
        class="bg-white p-8 rounded-2xl transition-all duration-300 hover:-translate-y-1 hover:shadow-lg"
      >
        <div
          class="w-10 h-10 bg-[#f5f5f7] rounded-xl flex items-center justify-center mb-6"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5 text-[#1d1d1f]"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
            ></path>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-[#1d1d1f] mb-2">Precision IA</h3>
        <p class="text-[#6e6e73] text-sm leading-relaxed">
          Modelos de inteligencia artificial que detectan hasta los detalles
          mas finos como cabello y pelaje.
        </p>
      </div>

      <div
        class="bg-white p-8 rounded-2xl transition-all duration-300 hover:-translate-y-1 hover:shadow-lg"
      >
        <div
          class="w-10 h-10 bg-[#f5f5f7] rounded-xl flex items-center justify-center mb-6"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5 text-[#1d1d1f]"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
            ></path>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-[#1d1d1f] mb-2">100% Privado</h3>
        <p class="text-[#6e6e73] text-sm leading-relaxed">
          Tus imagenes se procesan localmente en tu navegador.
          Nada se sube a ningun servidor.
        </p>
      </div>
    </div>
  </div>
</section>
